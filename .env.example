# Alpha Vantage — free tier at alphavantage.co (25 req/day)
# Required for commodity history charts (crude, gold, silver, copper, natgas)
# and macro indicators (CPI, GDP, Fed funds rate)
ALPHAVANTAGE_API_KEY=YOUR_AV_KEY_HERE

# GoldAPI — free tier at goldapi.io (~100 req/month)
# Required for real-time INR gold price
GOLDAPI_KEY=YOUR_GOLDAPI_KEY

# Commodity Price API — optional, improves commodity history data
COMMODITY_PRICE_API_KEY=YOUR_CPA_KEY

# Zerodha Kite Connect — optional, enables real-time MCX commodity prices
KITE_API_KEY=YOUR_KITE_API_KEY
KITE_ACCESS_TOKEN=YOUR_KITE_ACCESS_TOKEN

# Groww API — optional
GROWW_API_KEY=YOUR_API_KEY_HERE
GROWW_SECRET=YOUR_SECRET_HERE
